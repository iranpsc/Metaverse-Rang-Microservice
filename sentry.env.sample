# Shared Sentry configuration for all microservices
# Copy to .env in the repo root:  cp sentry.env.sample .env
# Docker Compose injects these into every service automatically.
# Do not add SENTRY_* vars to individual service config.env files.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
